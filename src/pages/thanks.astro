---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Thanks &mdash; we&rsquo;ll be in touch | Central Coast Tree Services"
  description="Your tree service request has been received. We'll be in touch within 1 business day to arrange a free on-site quote."
  canonical="https://centralcoasttreeservice.com.au/thanks/">
  <Fragment slot="head">
    <meta name="robots" content="noindex, follow">
  </Fragment>


  <section class="hero" style="padding: 4rem 0;">
    <div class="hero-inner">
      <span class="hero-eyebrow">Got it</span>
      <h1>Thanks &mdash; we&rsquo;ve got your details.</h1>
      <p class="hero-sub">
        We&rsquo;ll review your enquiry and call you back within 1 business day to
        arrange a free on-site quote. If you&rsquo;ve got a tree down or a dangerous
        limb right now, call us on
        <a class="ph-cta" href="/quote/" style="color:#bef264; text-decoration:underline;" aria-label="Call us"><span aria-hidden="true">&#9742;</span> <span class="ph-text">Tap to call</span></a>
        &mdash; we run 24/7 storm response.
      </p>
      <div class="hero-actions">
        <a class="ph-cta btn btn-primary" href="/quote/" aria-label="Call us"><span aria-hidden="true">&#9742;</span> <span class="ph-text">Tap to call</span></a>
        <a class="btn btn-ghost" href="/">Back to home</a>
      </div>
    </div>
  </section>
</Layout>
